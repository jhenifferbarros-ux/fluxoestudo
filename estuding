                <div class="bg-slate-900 text-slate-100 p-6 rounded-2xl shadow-xl relative font-mono text-xs overflow-x-auto">
                    <div class="flex justify-between items-center mb-4 pb-3 border-b border-slate-800 text-slate-400">
                        <span class="flex items-center gap-2"><i class="fa-solid fa-code text-google-yellow"></i> Google Apps Script (Code.gs)</span>
                        <button onclick="copyAppsScript()" class="bg-google-blue hover:bg-google-blueHover text-white px-3 py-1.5 rounded-lg font-sans font-medium text-xs transition-all flex items-center gap-1.5">
