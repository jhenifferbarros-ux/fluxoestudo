                    <pre id="scriptCodeBlock" class="leading-relaxed text-emerald-400">
/**
 * AUTOMAÇÃO DE CRONOGRAMA PCRR VUNESP - GOOGLE CALENDAR
 * Execute esta função uma única vez em script.google.com
 */
function criarCronogramaEstudosPCRR() {
  var agenda = CalendarApp.getDefaultCalendar();
  var hoje = new Date();
  
  // Grade de Horários
  var diasSemana = [
    { dia: 1, materia: "PCRR: Português + Direito Constitucional/Admin" }, // Segunda
    { dia: 2, materia: "PCRR: Matemática + Biossegurança (POPs 8.01/8.02)" }, // Terça
    { dia: 3, materia: "PCRR: Português + Estatuto Servidores RR" }, // Quarta
    { dia: 4, materia: "PCRR: Matemática + Noções de Arquivologia" }, // Quinta
    { dia: 5, materia: "PCRR: Informática + Laboratório (POP 8.03)" }   // Sexta
  ];
  
  Logger.log("Iniciando agendamento no Google Calendar...");

  // Agendar 4 semanas consecutivas
  for (var semana = 0; semana < 4; semana++) {
    // Aulas de Segunda a Sexta (19h às 21h)
    diasSemana.forEach(function(item) {
      var dataEvento = new Date(hoje.getTime() + (semana * 7 + (item.dia - hoje.getDay() + 7) % 7) * 86400000);
      dataEvento.setHours(19, 0, 0, 0);
      
      var fimEvento = new Date(dataEvento.getTime());
      fimEvento.setHours(21, 0, 0, 0);
      
      var evento = agenda.createEvent("📚 " + item.materia, dataEvento, fimEvento, {
        description: "Foco total no Estudo Ativo VUNESP. 15min Questões + 30min Teoria + 15min Anki.",
        location: "Mesa de Estudos"
      });
      evento.addPopupReminder(10); // Notificação no Celular 10min antes
    });

    // Simulado de Domingo (Manhã 08h-10h30 e Tarde 14h-16h30)
    var domManha = new Date(hoje.getTime() + (semana * 7 + (0 - hoje.getDay() + 7) % 7) * 86400000);
    domManha.setHours(8, 0, 0, 0);
    var domManhaFim = new Date(domManha.getTime());
    domManhaFim.setHours(10, 30, 0, 0);

    var evDom = agenda.createEvent("🎯 PCRR: Simulado de Questões VUNESP (Manhã)", domManha, domManhaFim, {
      description: "40 a 50 questões inéditas/anteriores sem consulta."
    });
    evDom.addPopupReminder(15);
  }
  
  Logger.log("Concluído! Verifique o aplicativo Google Agenda no seu smartphone.");
}
