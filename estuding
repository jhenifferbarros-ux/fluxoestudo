                            <div class="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                                <div id="barGeral" class="bg-google-blue h-full transition-all duration-500" style="width: 0%"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Stat Card 2 -->
                    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-4">
                        <div class="flex justify-between items-center">
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Bloco 2: Conhecimentos Específicos</span>
                            <span class="bg-amber-100 text-amber-700 text-xs font-bold px-2.5 py-0.5 rounded-full">Peso 2 (Max 80 pts)</span>
                        </div>
                        <div class="flex items-baseline gap-2">
                            <span id="scoreEspecifica" class="text-3xl font-bold text-slate-900">0</span>
                            <span class="text-sm text-slate-400">/ 80 pontos</span>
                        </div>
                        <div class="space-y-1">
                            <div class="flex justify-between text-xs font-medium">
                                <span class="text-slate-500">Mínimo para não ser eliminado: 40 pts</span>
                                <span id="statusEspecificaText" class="text-rose-500 font-bold">Abaixo do Mínimo</span>
                            </div>
                            <div class="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                                <div id="barEspecifica" class="bg-google-yellow h-full transition-all duration-500" style="width: 0%"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Chart Box -->
                <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                    <h3 class="font-bold text-sm text-slate-800 mb-4">Aproveitamento Mapeado por Matéria (%)</h3>
                    <div class="h-64">
                        <canvas id="performanceChart"></canvas>
                    </div>
                </div>
            </section>

        </main>
    </div>

    <!-- MODAL: ADD/EDIT ACCURACY & STATUS -->
    <div id="statusModal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm hidden items-center justify-center z-50 p-4">
        <div class="bg-white rounded-2xl max-w-md w-full p-6 space-y-5 shadow-2xl border border-slate-100">
            <div class="flex justify-between items-center">
                <h3 class="font-bold text-base text-slate-900" id="modalTopicTitle">Atualizar Desempenho</h3>
                <button onclick="closeStatusModal()" class="text-slate-400 hover:text-slate-600"><i class="fa-solid fa-xmark text-lg"></i></button>
            </div>
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-2">Taxa de Acertos na VUNESP (%)</label>
                    <input type="number" id="modalAccuracyInput" min="0" max="100" placeholder="Ex: 85" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-google-blue">
                </div>
            </div>
            <div class="flex justify-end gap-2">
                <button onclick="closeStatusModal()" class="px-4 py-2 rounded-xl text-xs font-semibold text-slate-600 hover:bg-slate-100">Cancelar</button>
                <button onclick="saveTopicAccuracy()" class="bg-google-blue text-white px-5 py-2 rounded-xl text-xs font-semibold shadow-md shadow-blue-500/20">Salvar Dados</button>
            </div>
        </div>
    </div>

    <!-- MODAL: ADD FLASHCARD -->
    <div id="newFlashcardModal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm hidden items-center justify-center z-50 p-4">
        <div class="bg-white rounded-2xl max-w-md w-full p-6 space-y-4 shadow-2xl border border-slate-100">
            <div class="flex justify-between items-center">
                <h3 class="font-bold text-base text-slate-900">Novo Flashcard Personalizado</h3>
                <button onclick="closeNewFlashcardModal()" class="text-slate-400 hover:text-slate-600"><i class="fa-solid fa-xmark text-lg"></i></button>
            </div>
            <div class="space-y-3">
                <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Categoria</label>
                    <input type="text" id="newFcCategory" placeholder="Ex: POP 8.03 ou Legislação" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-sm">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Pergunta / Conceito</label>
                    <textarea id="newFcQuestion" rows="3" placeholder="Ex: Qual o reagente recomendado para papiloscopia em superfícies porosas?" class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-sm"></textarea>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Resposta Oficial</label>
                    <textarea id="newFcAnswer" rows="3" placeholder="Ex: Ninidrina (reage com aminoácidos) e DFO." class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-sm"></textarea>
                </div>
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button onclick="closeNewFlashcardModal()" class="px-4 py-2 rounded-xl text-xs font-semibold text-slate-600">Cancelar</button>
                <button onclick="saveNewFlashcard()" class="bg-google-blue text-white px-5 py-2 rounded-xl text-xs font-semibold shadow-md shadow-blue-500/20">Criar Cartão</button>
            </div>
        </div>
    </div>

    <script>
        // Initial PCRR VUNESP Data Architecture
        const defaultSyllabus = [
            { id: 1, subject: "Língua Portuguesa", topic: "Compreensão de Texto, Crase, Concordância e Regência", weight: 1, block: "geral", source: "Caderno VUNESP", accuracy: 0, status: "Pendente" },
            { id: 2, subject: "Matemática", topic: "Resolução de Problemas, Regra de Três, Porcentagem e Equações", weight: 1, block: "geral", source: "Provas Anteriores", accuracy: 0, status: "Pendente" },
            { id: 3, subject: "Direito Constitucional e Admin.", topic: "Art. 5º e Art. 144 da CF/88; Atos e Poderes Administrativos", weight: 2, block: "especifica", source: "Constituição & VUNESP", accuracy: 0, status: "Pendente" },
            { id: 4, subject: "Legislação Estadual RR", topic: "Estatuto dos Servidores (LC 053/01) e Lei Orgânica PCRR (LC 055/01)", weight: 2, block: "especifica", source: "Legislação Seca", accuracy: 0, status: "Pendente" },
            { id: 5, subject: "Ciências & Biossegurança", topic: "Preservação de Local de Crime; POPs SENASP 8.01 e 8.02 (EPIs)", weight: 2, block: "especifica", source: "Manual SENASP Vol. 8", accuracy: 0, status: "Pendente" },
            { id: 6, subject: "Química Forense & Laboratório", topic: "Reagentes de Papiloscopia (POP 8.03: Ninidrina, Cianoacrilato, Amido Black)", weight: 2, block: "especifica", source: "Manual SENASP Vol. 8", accuracy: 0, status: "Pendente" },
            { id: 7, subject: "Criminalística & Asfixiologia", topic: "Vestígio vs. Indício; Enforcamento, Estrangulamento e Sufocação", weight: 2, block: "especifica", source: "Livro de Criminalística", accuracy: 0, status: "Pendente" },
            { id: 8, subject: "Noções de Arquivologia", topic: "Protocolo (Recebimento/Tramitação) e Tabela de Temporalidade", weight: 2, block: "especifica", source: "Resumo Técnico", accuracy: 0, status: "Pendente" },
            { id: 9, subject: "Conhecimentos de Informática", topic: "Ambiente Google (Docs, Sheets, Slides), Segurança e Nuvem", weight: 2, block: "especifica", source: "Google Help & VUNESP", accuracy: 0, status: "Pendente" }
        ];

        const defaultFlashcards = [
            { id: 1, category: "POP 8.03 SENASP", question: "Qual o reagente principal recomendado para revelação de impressões papilares em superfícies POROSAS (ex: papel/papelão)?", answer: "Ninidrina (reage com aminoácidos) e DFO (Diazafluorenona)." },
            { id: 2, category: "POP 8.03 SENASP", question: "Qual o método recomendado para superfícies NÃO POROSAS (ex: vidro, plástico, metal)?", answer: "Vaporização com Cianoacrilato (éster) seguida de aplicação de pós reveladores." },
            { id: 3, category: "POP 8.03 SENASP", question: "Qual reagente químico é utilizado especificamente para revelação de marcas em superfícies impregnadas com SANGUE?", answer: "Amido Black 10B (Acid Black 1) ou Leucocristal Violeta (LCV)." },
            { id: 4, category: "Criminalística Geral", question: "Qual a diferença conceitual entre VESTÍGIO e EVIDÊNCIA?", answer: "Vestígio é qualquer objeto/marca bruta encontrada no local. Evidência é o vestígio analisado com relação comprovada com o crime." },
            { id: 5, category: "Legislação de RR", question: "Qual a lei que instituiu o Estatuto dos Servidores Públicos do Estado de Roraima?", answer: "Lei Complementar Estadual nº 053/2001." },
            { id: 6, category: "CF/88 Art. 144", question: "A quem compete a apuração de infrações penais (exceto militares) e a função de polícia judiciária no âmbito estadual?", answer: "À Polícia Civil, dirigida por Delegado de Polícia de carreira." },
            { id: 7, category: "POP 8.01 Biossegurança", question: "Quais os EPIs mínimos obrigatórios para adentrar um local de crime com risco biológico?", answer: "Luvas de nitrila/látex, máscara PFF2/N95, macacão impermeável com capuz e sapatilhas pró-pé." }
        ];

        // Persistent State Storage
        let syllabusData = JSON.parse(localStorage.getItem('pcrr_syllabus')) || defaultSyllabus;
        let flashcardData = JSON.parse(localStorage.getItem('pcrr_flashcards')) || defaultFlashcards;
        let feynmanNotes = JSON.parse(localStorage.getItem('pcrr_feynman')) || [];

        let currentActiveFcIndex = 0;
        let activeEditTopicId = null;
        let chartInstance = null;

        window.onload = function() {
            renderSyllabus();
            renderFlashcard();
            renderFeynmanList();
            initChart();
            updateScores();
        };

        // Navigation Switcher
        function switchTab(tabId) {
            document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.add('hidden'));
            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('text-google-blue', 'bg-blue-50', 'border', 'border-blue-100');
                btn.classList.add('text-slate-600');
            });

            document.getElementById('tab-' + tabId).classList.remove('hidden');
            const activeNav = document.getElementById('nav-' + tabId);
            activeNav.classList.add('text-google-blue', 'bg-blue-50', 'border', 'border-blue-100');
            activeNav.classList.remove('text-slate-600');

            if (tabId === 'desempenho') {
                updateChart();
            }
        }

        // Render Syllabus Table
        function renderSyllabus() {
            const tbody = document.getElementById('syllabusTableBody');
            const filter = document.getElementById('filterWeight').value;
            tbody.innerHTML = '';

            syllabusData.forEach(item => {
                if (filter !== 'all' && item.block !== filter) return;

                let statusColor = 'bg-rose-100 text-rose-700';
                if (item.status === 'Em Revisão') statusColor = 'bg-amber-100 text-amber-700';
                if (item.status === 'Dominado') statusColor = 'bg-emerald-100 text-emerald-700';

                const tr = document.createElement('tr');
                tr.className = "hover:bg-slate-50/80 transition-all";
                tr.innerHTML = `
                    <td class="p-4">
                        <div class="font-bold text-slate-800">${item.subject}</div>
                        <div class="text-xs text-slate-500 max-w-xs">${item.topic}</div>
                    </td>
                    <td class="p-4">
                        <span class="inline-block ${item.weight === 2 ? 'bg-amber-100 text-amber-800 border-amber-200' : 'bg-slate-100 text-slate-700 border-slate-200'} text-[10px] font-bold px-2 py-0.5 rounded-md border">
                            Peso ${item.weight}
                        </span>
                    </td>
                    <td class="p-4 text-xs font-medium text-slate-600">${item.source}</td>
                    <td class="p-4">
                        <span class="inline-block ${statusColor} text-xs font-semibold px-2.5 py-1 rounded-full">
                            ${item.status}
                        </span>
                    </td>
                    <td class="p-4 text-center font-bold text-slate-800">
                        ${item.accuracy}%
                    </td>
                    <td class="p-4 text-right">
                        <button onclick="openStatusModal(${item.id})" class="bg-slate-100 hover:bg-slate-200 text-slate-700 px-3 py-1.5 rounded-lg text-xs font-medium border border-slate-200 transition-all">
                            Editar
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function openStatusModal(id) {
            activeEditTopicId = id;
            const item = syllabusData.find(x => x.id === id);
            document.getElementById('modalTopicTitle').innerText = item.subject + " (" + item.topic + ")";
            document.getElementById('modalAccuracyInput').value = item.accuracy;
            document.getElementById('statusModal').classList.remove('hidden');
            document.getElementById('statusModal').classList.add('flex');
        }

        function closeStatusModal() {
            document.getElementById('statusModal').classList.add('hidden');
            document.getElementById('statusModal').classList.remove('flex');
        }

        function saveTopicAccuracy() {
            const acc = parseInt(document.getElementById('modalAccuracyInput').value) || 0;
            const item = syllabusData.find(x => x.id === activeEditTopicId);
            item.accuracy = Math.min(100, Math.max(0, acc));

            if (item.accuracy >= 80) {
                item.status = "Dominado";
            } else if (item.accuracy >= 50) {
                item.status = "Em Revisão";
            } else {
                item.status = "Pendente";
            }

            localStorage.setItem('pcrr_syllabus', JSON.stringify(syllabusData));
            renderSyllabus();
            updateScores();
            closeStatusModal();
        }

        function updateScores() {
            let scoreG = 0; // max 20
            let scoreE = 0; // max 80

            syllabusData.forEach(item => {
                const proportionalScore = (item.accuracy / 100);
                if (item.block === 'geral') {
                    scoreG += proportionalScore * 10; // 10 pts per subject
                } else {
                    scoreE += proportionalScore * 11.4; // approx for 80 max
                }
            });

            scoreG = Math.round(scoreG);
            scoreE = Math.min(80, Math.round(scoreE));
            const total = scoreG + scoreE;

            document.getElementById('scoreGeral').innerText = scoreG;
            document.getElementById('scoreEspecifica').innerText = scoreE;
            document.getElementById('headerScore').innerText = `${total} / 100 pts`;
            document.getElementById('headerProgressBar').style.width = `${total}%`;

            // Status checks
            const statusG = document.getElementById('statusGeralText');
            if (scoreG >= 10) {
                statusG.innerText = "Aprovado no Mínimo";
                statusG.className = "text-emerald-600 font-bold";
            } else {
                statusG.innerText = "Abaixo do Mínimo (Eliminado)";
                statusG.className = "text-rose-500 font-bold";
            }

            const statusE = document.getElementById('statusEspecificaText');
            if (scoreE >= 40) {
                statusE.innerText = "Aprovado no Mínimo";
                statusE.className = "text-emerald-600 font-bold";
            } else {
                statusE.innerText = "Abaixo do Mínimo (Eliminado)";
                statusE.className = "text-rose-500 font-bold";
            }
        }

        function renderFlashcard() {
            if (flashcardData.length === 0) return;
            const card = flashcardData[currentActiveFcIndex];
            document.getElementById('flashcardQuestion').innerText = card.question;
            document.getElementById('flashcardAnswer').innerText = card.answer;
            document.getElementById('flashcardCategoryTag').innerText = card.category;
            document.getElementById('flashcardCounter').innerText = `Cartão ${currentActiveFcIndex + 1} de ${flashcardData.length}`;
            document.getElementById('flashcardBadge').innerText = flashcardData.length;

            // Reset flip state
            document.getElementById('flashcardInner').classList.remove('flipped');
        }

        function flipCard() {
            document.getElementById('flashcardInner').classList.toggle('flipped');
        }

        function rateFlashcard(rating) {
            currentActiveFcIndex = (currentActiveFcIndex + 1) % flashcardData.length;
            renderFlashcard();
        }

        function openNewFlashcardModal() {
            document.getElementById('newFlashcardModal').classList.remove('hidden');
            document.getElementById('newFlashcardModal').classList.add('flex');
        }

        function closeNewFlashcardModal() {
            document.getElementById('newFlashcardModal').classList.add('hidden');
            document.getElementById('newFlashcardModal').classList.remove('flex');
        }

        function saveNewFlashcard() {
            const cat = document.getElementById('newFcCategory').value || "Geral";
            const q = document.getElementById('newFcQuestion').value;
            const a = document.getElementById('newFcAnswer').value;

            if (!q || !a) return;

            flashcardData.push({
                id: Date.now(),
                category: cat,
                question: q,
                answer: a
            });

            localStorage.setItem('pcrr_flashcards', JSON.stringify(flashcardData));
            currentActiveFcIndex = flashcardData.length - 1;
            renderFlashcard();
            closeNewFlashcardModal();
        }

        function saveFeynmanNote() {
            const topic = document.getElementById('feynmanTopic').value;
            const content = document.getElementById('feynmanContent').value;

            if (!topic || !content) return;

            feynmanNotes.unshift({
                id: Date.now(),
                topic: topic,
                content: content,
                date: new Date().toLocaleDateString('pt-BR')
            });

            localStorage.setItem('pcrr_feynman', JSON.stringify(feynmanNotes));
            document.getElementById('feynmanTopic').value = '';
            document.getElementById('feynmanContent').value = '';
            renderFeynmanList();
        }

        function renderFeynmanList() {
            const container = document.getElementById('feynmanList');
            container.innerHTML = '';

            if (feynmanNotes.length === 0) {
                container.innerHTML = '<div class="text-xs text-slate-400 p-4 text-center">Nenhuma anotação criada ainda.</div>';
                return;
            }

            feynmanNotes.forEach(note => {
                const item = document.createElement('div');
                item.className = "bg-slate-50 border border-slate-200 p-3 rounded-xl space-y-1";
                item.innerHTML = `
                    <div class="flex justify-between items-center">
                        <span class="font-bold text-xs text-slate-800">${note.topic}</span>
                        <span class="text-[10px] text-slate-400">${note.date}</span>
                    </div>
                    <p class="text-xs text-slate-600 line-clamp-2">${note.content}</p>
                `;
                container.appendChild(item);
            });
        }

        function copyAppsScript() {
            const code = document.getElementById('scriptCodeBlock').innerText;
            const dummy = document.createElement("textarea");
            document.body.appendChild(dummy);
            dummy.value = code;
            dummy.select();
            document.execCommand("copy");
            document.body.removeChild(dummy);

            const btn = event.currentTarget;
            btn.innerHTML = `<i class="fa-solid fa-check"></i> Copiado!`;
            setTimeout(() => {
                btn.innerHTML = `<i class="fa-regular fa-copy"></i> Copiar Script`;
            }, 2000);
        }

        function initChart() {
            const ctx = document.getElementById('performanceChart').getContext('2d');
            chartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: syllabusData.map(x => x.subject),
                    datasets: [{
                        label: 'Taxa de Acertos (%)',
                        data: syllabusData.map(x => x.accuracy),
                        backgroundColor: '#1a73e8',
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 100
                        }
                    }
                }
            });
        }

        function updateChart() {
            if (!chartInstance) return;
            chartInstance.data.labels = syllabusData.map(x => x.subject);
            chartInstance.data.datasets[0].data = syllabusData.map(x => x.accuracy);
            chartInstance.update();
        }

        function resetDataModal() {
            if (confirm("Tem certeza que deseja resetar todos os dados de estudos para o padrão?")) {
                localStorage.clear();
                location.reload();
            }
        }
    </script>
</body>
</html>
